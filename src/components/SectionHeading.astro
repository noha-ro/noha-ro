---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, lead, align = 'left' } = Astro.props;
---

<div class:list={['heading', align]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="section-title">{title}</h2>
  {lead && <p class="section-lead">{lead}</p>}
</div>

<style>
  .heading {
    margin-bottom: 2rem;
  }

  .heading.center {
    text-align: center;
  }

  .heading.center .section-title,
  .heading.center .section-lead {
    margin-inline: auto;
  }
</style>

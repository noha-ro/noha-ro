---
interface Props {
  name: string;
  url: string;
  image: string;
  category: string;
}

const { name, url, image, category } = Astro.props;
---

<a class="project" href={url} target="_blank" rel="noopener noreferrer">
  <div class="media">
    <img src={image} alt={`Screenshot ${name}`} loading="lazy" width="1024" height="600" />
  </div>
  <div class="meta">
    <span>{category}</span>
    <strong>{name}</strong>
  </div>
</a>

<style>
  .project {
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .project:hover {
    transform: translateY(-5px);
    box-shadow: 0 24px 60px rgba(40, 33, 76, 0.14);
  }

  .media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-wash-2);
  }

  .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .project:hover .media img {
    transform: scale(1.04);
  }

  .meta {
    padding: 1rem 1.15rem 1.2rem;
    display: grid;
    gap: 0.2rem;
  }

  .meta span {
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .meta strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-ink-soft);
  }
</style>
